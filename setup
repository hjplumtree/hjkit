#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_NAMES=("ui-builder" "ui-review")
FORCE=0
PROJECT_PATH=""
PROJECT_SKILLS_DIR=""

# Paths:
# - source root: canonical skill source inside this repo
# - user discovery root: where Codex finds skills after local install
# - project discovery root: created only when --repo is used
OFFICIAL_SKILLS_DIR="$HOME/.codex/skills"
LEGACY_USER_SKILLS_DIR="$HOME/.agents/skills"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force)
      FORCE=1
      shift
      ;;
    --repo)
      if [ -z "${2:-}" ]; then
        echo "--repo requires a path"
        exit 1
      fi
      PROJECT_PATH="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

mkdir -p "$OFFICIAL_SKILLS_DIR"

backup_if_exists() {
  local target="$1"
  if [ -e "$target" ] || [ -L "$target" ]; then
    local backup="${target}.bak.$(date +%Y%m%d%H%M%S)"
    cp -R "$target" "$backup" 2>/dev/null || cp -RL "$target" "$backup"
    echo "Backed up existing path to: $backup"
  fi
}

confirm_overwrite() {
  local target="$1"
  if [ -e "$target" ] || [ -L "$target" ]; then
    if [ "$FORCE" -ne 1 ]; then
      echo "Existing path found: $target"
      echo "A backup will be created before overwrite."
      read -r -p "Continue? [y/N] " ans
      if [ "$ans" != "y" ] && [ "$ans" != "Y" ]; then
        echo "Cancelled."
        exit 1
      fi
    fi
  fi
}

install_file_with_backup() {
  local source_file="$1"
  local target_file="$2"

  confirm_overwrite "$target_file"
  backup_if_exists "$target_file"
  cp "$source_file" "$target_file"
  echo "Installed file: $target_file"
}

install_project_file_with_backup() {
  local source_file="$1"
  local target_file="$2"

  backup_if_exists "$target_file"
  cp "$source_file" "$target_file"
  echo "Installed file: $target_file"
}

ensure_project_gitignore_entry() {
  local gitignore_file="$1"
  local entry="$2"

  mkdir -p "$(dirname "$gitignore_file")"
  if [ ! -e "$gitignore_file" ]; then
    printf "%s\n" "$entry" > "$gitignore_file"
    echo "Created .gitignore with entry: $entry"
    return
  fi

  if ! grep -Fxq "$entry" "$gitignore_file"; then
    printf "\n# hjkit local discovery\n%s\n" "$entry" >> "$gitignore_file"
    echo "Updated .gitignore with entry: $entry"
  fi
}

link_skill_discovery() {
  local source_dir="$1"
  local link_path="$2"

  confirm_overwrite "$link_path"
  backup_if_exists "$link_path"
  rm -rf "$link_path"
  ln -s "$source_dir" "$link_path"
}

cleanup_legacy_user_links() {
  for skill_name in "${SKILL_NAMES[@]}"; do
    rm -rf "$LEGACY_USER_SKILLS_DIR/hjkit-$skill_name"
  done
  rmdir "$LEGACY_USER_SKILLS_DIR" 2>/dev/null || true
  rmdir "$(dirname "$LEGACY_USER_SKILLS_DIR")" 2>/dev/null || true
}

for skill_name in "${SKILL_NAMES[@]}"; do
  link_skill_discovery "$ROOT_DIR/skills/$skill_name" "$OFFICIAL_SKILLS_DIR/hjkit-$skill_name"
done

cleanup_legacy_user_links

if [ -n "$PROJECT_PATH" ]; then
  mkdir -p "$PROJECT_PATH"
  install_project_file_with_backup "$ROOT_DIR/project-template/AGENTS.md" "$PROJECT_PATH/AGENTS.md"
  install_project_file_with_backup "$ROOT_DIR/project-template/DESIGN_SYSTEM.md" "$PROJECT_PATH/DESIGN_SYSTEM.md"

  PROJECT_SKILLS_DIR="$PROJECT_PATH/.agents/skills"
  mkdir -p "$PROJECT_SKILLS_DIR"
  for skill_name in "${SKILL_NAMES[@]}"; do
    link_skill_discovery "$ROOT_DIR/skills/$skill_name" "$PROJECT_SKILLS_DIR/hjkit-$skill_name"
  done
  echo "Repo-local skill links created in: $PROJECT_SKILLS_DIR"

  ensure_project_gitignore_entry "$PROJECT_PATH/.gitignore" ".agents/"
fi

echo "✅ Installed:"
echo "  - $ROOT_DIR/skills/ui-builder"
echo "  - $ROOT_DIR/skills/ui-review"
echo "  - symlinked to $OFFICIAL_SKILLS_DIR/hjkit-ui-builder"
echo "  - symlinked to $OFFICIAL_SKILLS_DIR/hjkit-ui-review"
echo "  - project template AGENTS.md / DESIGN_SYSTEM.md when --repo is used"
echo
echo "Next:"
echo "1. In Codex, use hjkit-ui-builder or hjkit-ui-review."
